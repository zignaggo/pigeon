{
  "name": "pigeon",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:expose": "vite dev --port 3000 --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "dev:desktop": "bun run --env-file=.env tauri dev",
    "dev:android": "bun run --env-file=.env tauri android dev",
